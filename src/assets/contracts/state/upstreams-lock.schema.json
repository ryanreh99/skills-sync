{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Upstreams Lockfile",
  "type": "object",
  "additionalProperties": false,
  "anyOf": [
    {
      "required": [
        "pins"
      ]
    },
    {
      "required": [
        "imports"
      ]
    }
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "pins": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "upstream",
          "ref",
          "commit"
        ],
        "properties": {
          "upstream": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "commit": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{7,40}$"
          }
        }
      }
    },
    "imports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile",
          "upstream",
          "selectionPath",
          "destRelative",
          "contentHash",
          "installedAt"
        ],
        "properties": {
          "profile": {
            "type": "string",
            "minLength": 1
          },
          "upstream": {
            "type": "string",
            "minLength": 1
          },
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "originalInput": {
            "type": "string",
            "minLength": 1
          },
          "selectionPath": {
            "type": "string",
            "minLength": 1
          },
          "destRelative": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "tracking": {
            "type": "string",
            "enum": [
              "floating",
              "pinned"
            ]
          },
          "resolvedRevision": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "latestRevision": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "contentHash": {
            "type": "string",
            "minLength": 1
          },
          "installedAt": {
            "type": "string",
            "minLength": 1
          },
          "refreshedAt": {
            "type": "string",
            "minLength": 1
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "materializedAgents": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "mode"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "mode": {
                  "type": "string",
                  "minLength": 1
                },
                "appliedAt": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
