{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Upstreams Lockfile",
  "type": "object",
  "additionalProperties": false,
  "anyOf": [
    {
      "required": [
        "pins"
      ]
    },
    {
      "required": [
        "imports"
      ]
    }
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 3
    },
    "pins": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "upstream",
          "ref",
          "resolvedRevision"
        ],
        "properties": {
          "upstream": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "resolvedRevision": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{7,40}$"
          },
          "sourceIdentity": {
            "type": "string",
            "minLength": 1
          },
          "sourceDescriptor": {
            "type": "object"
          },
          "updatedAt": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "imports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile",
          "upstream",
          "selectionPath",
          "destRelative"
        ],
        "anyOf": [
          {
            "required": [
              "contentHash",
              "installedAt"
            ]
          },
          {
            "required": [
              "source",
              "resolution",
              "digests",
              "projection",
              "refresh",
              "eval"
            ]
          }
        ],
        "properties": {
          "profile": {
            "type": "string",
            "minLength": 1
          },
          "upstream": {
            "type": "string",
            "minLength": 1
          },
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "originalInput": {
            "type": "string",
            "minLength": 1
          },
          "selectionPath": {
            "type": "string",
            "minLength": 1
          },
          "destRelative": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "tracking": {
            "type": "string",
            "enum": [
              "floating",
              "pinned"
            ]
          },
          "resolvedRevision": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "latestRevision": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "contentHash": {
            "type": "string",
            "minLength": 1
          },
          "installedAt": {
            "type": "string",
            "minLength": 1
          },
          "refreshedAt": {
            "type": "string",
            "minLength": 1
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "materializedAgents": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "mode"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "mode": {
                  "type": "string",
                  "minLength": 1
                },
                "appliedAt": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "sourceIdentity": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "provider",
              "originalInput",
              "descriptor"
            ],
            "properties": {
              "provider": {
                "type": "string",
                "minLength": 1
              },
              "originalInput": {
                "type": "string",
                "minLength": 1
              },
              "identity": {
                "type": "string",
                "minLength": 1
              },
              "descriptor": {
                "type": "object"
              }
            }
          },
          "resolution": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "tracking"
            ],
            "properties": {
              "tracking": {
                "type": "string",
                "enum": [
                  "floating",
                  "pinned"
                ]
              },
              "ref": {
                "type": "string",
                "minLength": 1
              },
              "resolvedRevision": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "latestRevision": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              }
            }
          },
          "digests": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "contentSha256"
            ],
            "properties": {
              "contentSha256": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "projection": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "adapters",
              "materializedAgents"
            ],
            "properties": {
              "adapters": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "contractVersion"
                  ],
                  "properties": {
                    "contractVersion": {
                      "type": "integer",
                      "minimum": 1
                    },
                    "skillsMethod": {
                      "type": "string",
                      "minLength": 1
                    },
                    "mcpMethod": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              },
              "materializedAgents": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "id",
                    "mode"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "mode": {
                      "type": "string",
                      "minLength": 1
                    },
                    "appliedAt": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          },
          "refresh": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "installedAt"
            ],
            "properties": {
              "installedAt": {
                "type": "string",
                "minLength": 1
              },
              "lastRefreshedAt": {
                "type": "string",
                "minLength": 1
              },
              "lastOutcome": {
                "type": "string",
                "enum": [
                  "changed",
                  "unchanged",
                  "pinned",
                  "error"
                ]
              },
              "changed": {
                "type": "boolean"
              }
            }
          },
          "eval": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "type": "string",
                "minLength": 1
              },
              "updatedAt": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
