{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Build Bundle Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "profile",
    "generatedAt",
    "sources"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "projectionContracts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contractVersion"
        ],
        "properties": {
          "contractVersion": {
            "type": "integer",
            "minimum": 1
          },
          "skillsMethod": {
            "type": "string",
            "minLength": 1
          },
          "mcpMethod": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packPath",
        "imports"
      ],
      "properties": {
        "packPath": {
          "type": "string",
          "minLength": 1
        },
        "imports": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "upstream",
              "path",
              "destPrefix"
            ],
            "properties": {
              "upstream": {
                "type": "string",
                "minLength": 1
              },
              "provider": {
                "type": "string",
                "minLength": 1
              },
              "ref": {
                "type": "string",
                "minLength": 1
              },
              "commit": {
                "type": "string",
                "minLength": 7
              },
              "tracking": {
                "type": "string",
                "enum": [
                  "floating",
                  "pinned"
                ]
              },
              "sourceIdentity": {
                "type": "string",
                "minLength": 1
              },
              "originalInput": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "destPrefix": {
                "type": "string",
                "minLength": 1
              },
              "contentHash": {
                "type": "string",
                "minLength": 1
              },
              "capabilities": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
