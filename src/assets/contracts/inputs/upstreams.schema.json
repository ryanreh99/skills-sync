{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Upstreams Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "upstreams"
  ],
  "properties": {
    "upstreams": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "repo",
          "defaultRef"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "git"
            ]
          },
          "repo": {
            "type": "string",
            "minLength": 1
          },
          "defaultRef": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

