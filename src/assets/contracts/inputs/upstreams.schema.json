{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Upstreams Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "upstreams"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1,
        2,
        3
      ]
    },
    "upstreams": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id"
        ],
        "anyOf": [
          {
            "required": [
              "repo"
            ]
          },
          {
            "required": [
              "path"
            ]
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "provider": {
            "type": "string",
            "enum": [
              "git",
              "local-path",
              "http-well-known"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "git"
            ]
          },
          "originalInput": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "root": {
            "type": "string",
            "minLength": 1
          },
          "defaultRef": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "sourceIdentity": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
