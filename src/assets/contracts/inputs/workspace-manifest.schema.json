{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "skills-sync Workspace Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workspace"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profiles",
        "upstreams"
      ],
      "properties": {
        "defaultProfile": {
          "type": "string",
          "minLength": 1
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "profile",
              "pack"
            ],
            "properties": {
              "profile": {
                "type": "object"
              },
              "pack": {
                "type": "object"
              }
            }
          }
        },
        "upstreams": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    }
  }
}
