{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "packPath"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1,
        2
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "packPath": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "extends": {
      "type": "string",
      "minLength": 1
    },
    "agentOverrides": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object"
      }
    }
  }
}
