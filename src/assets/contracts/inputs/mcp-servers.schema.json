{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MCP Servers Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "servers"
  ],
  "properties": {
    "servers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "anyOf": [
          {
            "required": [
              "command"
            ]
          },
          {
            "required": [
              "url"
            ]
          }
        ],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "env": {
            "type": "object",
            "propertyNames": {
              "type": "string",
              "minLength": 1
            },
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
