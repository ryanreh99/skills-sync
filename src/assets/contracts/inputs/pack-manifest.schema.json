{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "maintainer": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

